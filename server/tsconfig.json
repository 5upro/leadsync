{
	"compilerOptions": {
		"target": "ES2020",
		"module": "CommonJS",
		"rootDir": "src",
		"outDir": "dist",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"baseUrl": ".",
		"ignoreDeprecations": "6.0",
        "paths": {
            "@/*": ["src/*"]
        }
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist"]
}
